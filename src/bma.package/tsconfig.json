{
  "compilerOptions": {
    "target": "ES5",
    "sourceMap": true,
    "noImplicitAny": false,
    "noEmitOnError": false,
    "removeComments": false,
    "jsx": "preserve",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false
  },
  "include": [
    "app.ts",
    "script/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "test"
  ]
}
